    "import torch\n",
    " \n",
    "print(f\"PyTorch version {torch.__version__}\")\n",
    "if torch.cuda.is_available():\n",
    "    print(\"CUDA GPU\")\n",
    "elif torch.xpu.is_available():\n",
    "    print(\"Intel GPU\")\n",
    "elif torch.mps.is_available():\n",
    "    print(\"Apple Silicon GPU\")\n",
    " \n",
    "else:\n",
    "    print(\"Only CPU\")"
   ]
